{
  "name": "marky",
  "version": "0.2.1",
  "private": false,
  "bin": {
    "marky": "server/dist/cli.js"
  },
  "files": [
    "server/dist",
    "client/dist",
    "shared/dist",
    "package.json",
    "README.md"
  ],
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "pack:dry": "npm pack --json --dry-run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.0.0",
    "chokidar": "^5.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.8.0",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.13.0",
    "minisearch": "^7.2.0",
    "open": "^10.1.2"
  }
}
